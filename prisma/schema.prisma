generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  password     String
  role         String   @default("USER") // ADMIN or USER
  credits      Int      @default(0)
  referralCode String   @unique // e.g. NF-XXXXXX
  referredBy   String?  // referral code of who invited them
  checkerUsesToday Int      @default(0)
  checkerResetDate DateTime @default(now())
  ipAddress    String?  // IP at registration
  fingerprint  String?  // browser fingerprint
  region       String?  // ISO country code (e.g., PE, MX)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions  Transaction[]
  referrals     User[]      @relation("Referrals")
  referrer      User?       @relation("Referrals", fields: [referredBy], references: [referralCode])
  createdKeys   GiftKey[]   @relation("CreatedKeys")
  redeemedKeys  GiftKey[]   @relation("RedeemedKeys")
}

model Cookie {
  id        String   @id @default(cuid())
  rawCookie String
  status    String   @default("ACTIVE") // ACTIVE or DEAD
  usedCount Int      @default(0)
  lastUsed  DateTime?
  lastError String?
  country   String?
  plan      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // GENERATE_TOKEN, COPY_COOKIE, ADMIN_GRANT, ADMIN_DEDUCT, REFERRAL_BONUS, REGISTER_BONUS
  credits     Int      // positive for grants, negative for usage
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model GiftKey {
  id          String    @id @default(cuid())
  code        String    @unique  // e.g. HJFLIX-A3K9M
  credits     Int
  createdBy   String    // admin userId
  redeemedBy  String?   // user userId who redeemed
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())

  creator     User      @relation("CreatedKeys", fields: [createdBy], references: [id])
  redeemer    User?     @relation("RedeemedKeys", fields: [redeemedBy], references: [id])
}
